{
  "namespace": "server_form",
  "third_party_server_screen@common.base_screen": {
    "$screen_content": "server_form.screen",
    "button_mappings": [
      {
        "from_button_id": "button.menu_cancel",
        "to_button_id": "button.menu_exit",
        "mapping_type": "global"
      }
    ]
  },
  "screen": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "server_form_factory": {
          "type": "factory",
          "control_ids": {
            "long_form": "@server_form.long_form",
            "custom_form": "@server_form.custom_form"
          }
        }
      }
    ]
  },
  "long_form": {
    "type": "panel",
    "$forminv_prefix": "§c",
    "size": ["100%", "100%"],
    "controls": [
      {
        "forminv_chest@forminv.chest_panel": {
          "bindings": [
            {
              "binding_type": "global",
              "binding_condition": "once",
              "binding_name": "#title_text",
              "binding_name_override": "#title_text"
            },
            {
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#collection_length",
              "binding_name_override": "#button_count"
            },
            {
              "source_property_name": "(not((#title_text - $forminv_prefix) = #title_text))",
              "binding_type": "view",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },
  "custom_form": {
    "type": "panel",
    "visible": false
  }
}
